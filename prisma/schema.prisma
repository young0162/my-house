// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum BadgeType {
  BEST
  NEW
}

enum UserRole {
  USER
  ADMIN
}

enum ProductImageType {
  THUMBNAIL
  GALLERY
  DETAIL
}

enum CheckoutSource {
  PRODUCT_DETAIL
  CART
}

enum CheckoutStatus {
  PENDING
  EXPIRED
  ORDERED
}

enum OrderStatus {
  PAID
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
}

model Product {
  id             Int        @id @default(autoincrement())
  image          String
  brandId        Int        @map("brand_id")
  brand          Brand      @relation(fields: [brandId], references: [id])
  name           String
  description    String?    @db.Text
  price          Int
  originalPrice  Int?       @map("original_price")
  isFreeShipping Boolean    @default(false) @map("is_free_shipping")
  isActive       Boolean    @default(true) @map("is_active")
  stock          Int        @default(0)
  badge          BadgeType?
  categoryId     Int?       @map("category_id")
  category       Category?  @relation(fields: [categoryId], references: [id])
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  productOptions ProductOption[]
  reviews        Review[]
  productCoupons ProductCoupon[]
  carts          Cart[]
  productImages  ProductImage[]
  checkoutItems  CheckoutItem[]

  @@index([brandId])
  @@index([categoryId])
  @@map("product")
}

model ProductImage {
  id        Int              @id @default(autoincrement())
  productId Int              @map("product_id")
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  type      ProductImageType
  sortOrder Int              @default(0) @map("sort_order")
  alt       String?

  @@index([productId])
  @@index([type])
  @@map("product_image")
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String
  slug      String?
  depth     Int
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  parentId Int?       @map("parent_id")
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([depth])
  @@index([isActive, sortOrder])
  @@map("category")
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  logo     String?
  visible  Boolean   @default(true)
  products Product[]

  @@index([visible])
  @@map("brand")
}

model ProductOption {
  id           Int @id @default(autoincrement())
  optionTypeId Int @map("option_type_id")
  productId    Int @map("product_id")

  optionType          OptionType           @relation(fields: [optionTypeId], references: [id])
  product             Product              @relation(fields: [productId], references: [id])
  productOptionValues ProductOptionValue[]

  @@unique([productId, optionTypeId])
  @@index([productId])
  @@index([optionTypeId])
  @@map("product_option")
}

model OptionType {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  productOptions ProductOption[]
  optionValues   OptionValue[]

  @@unique([name])
  @@index([name])
  @@map("option_type")
}

model OptionValue {
  id     Int    @id @default(autoincrement())
  value  String @db.VarChar(100)
  typeId Int    @map("type_id")

  type                OptionType           @relation(fields: [typeId], references: [id])
  productOptionValues ProductOptionValue[]
  cartOptions         CartOption[]
  checkoutItemOptions CheckoutItemOption[]

  @@unique([typeId, value])
  @@index([typeId])
  @@map("option_value")
}

model ProductOptionValue {
  id              Int @id @default(autoincrement())
  productOptionId Int @map("product_option_id")
  optionValueId   Int @map("option_value_id")

  productOption ProductOption @relation(fields: [productOptionId], references: [id])
  optionValue   OptionValue   @relation(fields: [optionValueId], references: [id])

  @@unique([productOptionId, optionValueId])
  @@index([productOptionId])
  @@index([optionValueId])
  @@map("product_option_value")
}

model Review {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  orderItemId Int       @unique @map("order_item_id")
  name        String
  image       String?
  productId   Int?      @map("product_id")
  rating      Int
  description String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  answeredAt  DateTime? @map("answered_at")

  user      User      @relation(fields: [userId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  product   Product?  @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([orderItemId])
  @@index([productId])
  @@index([createdAt])
  @@map("review")
}

model Coupon {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")
  useStartAt      DateTime @map("use_start_at")
  useEndAt        DateTime @map("use_end_at")
  discountPercent Int      @map("discount_percent")

  productCoupons ProductCoupon[]

  @@index([useStartAt, useEndAt])
  @@map("coupon")
}

model ProductCoupon {
  id        Int @id @default(autoincrement())
  productId Int @map("product_id")
  couponId  Int @map("coupon_id")

  product Product @relation(fields: [productId], references: [id])
  coupon  Coupon  @relation(fields: [couponId], references: [id])

  @@unique([productId, couponId])
  @@index([productId])
  @@index([couponId])
  @@map("product_coupon")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  count     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  cartOptions CartOption[]

  @@index([userId])
  @@index([productId])
  @@map("cart")
}

model CartOption {
  id            Int @id @default(autoincrement())
  cartId        Int @map("cart_id")
  optionValueId Int @map("option_value_id")

  cart        Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  optionValue OptionValue @relation(fields: [optionValueId], references: [id])

  @@unique([cartId, optionValueId])
  @@index([cartId])
  @@index([optionValueId])
  @@map("cart_option")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  carts         Cart[]
  checkouts     Checkout[]
  addresses     UserAddress[]
  orders        Order[]
  reviews       Review[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([createdAt])
  @@index([deletedAt, createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UserAddress {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id")
  recipientName String    @map("recipient_name") @db.VarChar(50)
  phoneNumber   String    @map("phone_number") @db.VarChar(30)
  zipCode       String?   @map("zip_code") @db.VarChar(20)
  address       String    @db.VarChar(255)
  detailAddress String?   @map("detail_address") @db.VarChar(255)
  isDefault     Boolean   @default(false) @map("is_default")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@index([userId, deletedAt])
  @@map("user_address")
}

model Checkout {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  source    CheckoutSource
  status    CheckoutStatus @default(PENDING)
  expiresAt DateTime?      @map("expires_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CheckoutItem[]

  @@index([userId, status, createdAt])
  @@index([expiresAt])
  @@map("checkout")
}

model CheckoutItem {
  id         Int    @id @default(autoincrement())
  checkoutId String @map("checkout_id")
  productId  Int    @map("product_id")
  cartId     Int?   @map("cart_id")
  quantity   Int
  sortOrder  Int    @default(0) @map("sort_order")

  checkout Checkout            @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  product  Product             @relation(fields: [productId], references: [id])
  options  CheckoutItemOption[]

  @@index([checkoutId])
  @@index([productId])
  @@index([cartId])
  @@map("checkout_item")
}

model CheckoutItemOption {
  id             Int @id @default(autoincrement())
  checkoutItemId Int @map("checkout_item_id")
  optionValueId  Int @map("option_value_id")

  checkoutItem CheckoutItem @relation(fields: [checkoutItemId], references: [id], onDelete: Cascade)
  optionValue  OptionValue  @relation(fields: [optionValueId], references: [id])

  @@unique([checkoutItemId, optionValueId])
  @@index([checkoutItemId])
  @@index([optionValueId])
  @@map("checkout_item_option")
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  checkoutId    String?     @map("checkout_id")
  status        OrderStatus @default(PAID)

  // 주문자 정보 스냅샷
  ordererName   String      @map("orderer_name")  @db.VarChar(100)
  ordererEmail  String      @map("orderer_email") @db.VarChar(200)
  ordererPhone  String      @map("orderer_phone") @db.VarChar(30)

  // 배송지 스냅샷
  recipientName   String  @map("recipient_name")   @db.VarChar(50)
  recipientPhone  String  @map("recipient_phone")  @db.VarChar(30)
  zipCode         String? @map("zip_code")         @db.VarChar(20)
  address         String  @db.VarChar(255)
  detailAddress   String? @map("detail_address")   @db.VarChar(255)
  deliveryRequest String? @map("delivery_request") @db.VarChar(200)

  // 결제 정보
  paymentMethod      String @map("payment_method")       @db.VarChar(50)
  totalProductPrice  Int    @map("total_product_price")
  shippingFee        Int    @default(0) @map("shipping_fee")
  couponDiscount     Int    @default(0) @map("coupon_discount")
  pointDiscount      Int    @default(0) @map("point_discount")
  finalPrice         Int    @map("final_price")
  pointEarned        Int    @default(0) @map("point_earned")

  orderedAt DateTime @default(now()) @map("ordered_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId, orderedAt])
  @@index([status, orderedAt])
  @@map("order")
}

model OrderItem {
  id      Int    @id @default(autoincrement())
  orderId String @map("order_id")

  // 상품 정보 스냅샷 (외부 참조 없음)
  productName    String  @map("product_name")    @db.VarChar(255)
  brandName      String  @map("brand_name")      @db.VarChar(100)
  productImage   String  @map("product_image")   @db.VarChar(500)
  optionLabel    String? @map("option_label")    @db.VarChar(300)
  price          Int
  originalPrice  Int?    @map("original_price")
  quantity       Int
  isFreeShipping Boolean @default(false) @map("is_free_shipping")
  deliveryMethod String  @map("delivery_method") @db.VarChar(100)

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  review Review?

  @@index([orderId])
  @@map("order_item")
}
